k <- (nchar(my_first) + my_birth_year) %% 15 + 8
my_first <- "Caner"
my_birth_year <- 2002
k <- (nchar(my_first) + my_birth_year) %% 15 + 8
k
library(dslabs)
data("polls_us_election_2016")
poll_data <- polls_us_election_2016
if (k %% 2 == 0) {
head(poll_data, k)
} else {
tail(poll_data, k)
}
sum(is.na(poll_data))
na_per_column <- colSums(is.na(poll_data))
sort(na_per_column, decreasing = TRUE)[1:8]
new_data <- poll_data
for (i in 1:ncol(new_data)) {
if (is.numeric(new_data[[i]])) {
new_data[[i]][is.na(new_data[[i]])] <- my_birth_year + k
} else if (is.character(new_data[[i]])) {
new_data[[i]][is.na(new_data[[i]])] <- paste0(my_first, "_", k)
} else if (is.factor(new_data[[i]])) {
new_data[[i]] <- as.character(new_data[[i]])
new_data[[i]][is.na(new_data[[i]])] <- paste0(my_first, "_", k)
} else if (inherits(new_data[[i]], "Date")) {
new_data[[i]][is.na(new_data[[i]])] <- as.Date("2002-01-01")
}
}
if (k %% 2 == 0) {
head(new_data, k)
} else {
tail(new_data, k)
}
sum(is.na(new_data))
anyNA(new_data)
